{
  /*
   * ==========================================================================
   * EDITOR CORE & VIM BEHAVIOR
   * ==========================================================================
   */
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "cursor_blink": false,
  "tab_size": 2,
  "extend_comment_on_newline": false,
  "vertical_scroll_margin": 1,
  "when_closing_with_no_tabs": "keep_window_open",
  "close_on_file_delete": true,
  "autosave": "on_focus_change",
  "auto_indent": true,
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,

  /*
   * ==========================================================================
   * AI & AGENT RESTRICTIONS (DISABLED)
   * ==========================================================================
   */
  "disable_ai": true,
  "agent": {
    "button": false,
  },

  /*
   * ==========================================================================
   * SYSTEM PERFORMANCE & NODE.JS TOOLING
   * ==========================================================================
   */
  "file_scan_exclusions": [
    "**/.git",
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/coverage",
    "**/.next",
  ],
  "formatter": "prettier",
  "lsp": {
    "eslint": {
      "settings": {
        "codeActionOnSave": {
          "rules": ["ext:js,jsx,ts,tsx"],
        },
      },
    },
  },

  /*
   * ==========================================================================
   * TYPOGRAPHY & FONTS
   * ==========================================================================
   */
  "ui_font_size": 12,
  "ui_font_family": "ComicShannsMono Nerd Font Mono",
  "buffer_font_size": 12,
  "buffer_font_family": "ComicShannsMono Nerd Font Mono",
  "terminal": {
    "dock": "bottom",
    "font_family": "ComicShannsMono Nerd Font Mono",
    "font_size": 12,
  },

  /*
   * ==========================================================================
   * VISUAL THEME & UI SURFACES
   * ==========================================================================
   */
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Espresso (Blur) [Heavy]",
  },
  "icon_theme": "Warm Charmed Icons",
  "scrollbar": {
    "show": "never",
  },
  "title_bar": {
    "show_onboarding_banner": false,
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "gutter": {
    "min_line_number_digits": 4,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },

  /*
   * ==========================================================================
   * PROJECT PANEL & NAVIGATION
   * ==========================================================================
   */
  "project_panel": {
    "hide_gitignore": false,
    "hide_hidden": false,
    "auto_fold_dirs": false,
    "starts_open": false,
    "scrollbar": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "small",
    "include_ignored": "indexed",
  },

  /*
   * ==========================================================================
   * THEME OVERRIDES (AURA DARK)
   * ==========================================================================
   */
  "theme_overrides": {
    "Catppuccin Espresso (Blur) [Heavy]": {
      "tab.active_background": "#2a283e55",

      "editor.line_number": "#585273",
      "editor.active_line_number": "#A277FF",

      "vim.normal.background": "#A277FF",
      "vim.normal.foreground": "#15141C",

      "vim.insert.background": "#00E599",
      "vim.insert.foreground": "#15141C",

      "vim.visual.background": "#FFB86C",
      "vim.visual.foreground": "#15141C",

      "vim.replace.background": "#FF5555",
      "vim.replace.foreground": "#15141C",

      "vim.visual_line.background": "#7199FF",
      "vim.visual_line.foreground": "#15141C",

      "syntax": {
        "comment": { "font_style": "italic" },
        "comment.doc": { "font_style": "italic" },
      },
    },
  },
}

